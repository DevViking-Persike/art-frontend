@namespace Testedecriacao.Shared.Components.Molecules
@using Testedecriacao.Shared.Components.Atoms

<div class="cart-item d-flex align-items-center gap-3 p-2 border-bottom @CssClass">
    <img src="@ImageUrl" alt="@Name" class="cart-item-image rounded" />
    <div class="cart-item-info flex-grow-1">
        <h6 class="mb-0">@Name</h6>
        <PriceTag Price="@Price" CssClass="small" />
    </div>
    <QuantitySelector Value="@Quantity" ValueChanged="HandleQuantityChanged" />
    <div class="cart-item-subtotal text-end">
        <strong>@((Price * Quantity).ToString("C"))</strong>
    </div>
    <button class="btn btn-outline-danger btn-sm" @onclick="() => OnRemove.InvokeAsync(ProductId)">
        &#10005;
    </button>
</div>

@code {
    [Parameter, EditorRequired] public int ProductId { get; set; }
    [Parameter, EditorRequired] public string Name { get; set; } = "";
    [Parameter, EditorRequired] public string ImageUrl { get; set; } = "";
    [Parameter, EditorRequired] public decimal Price { get; set; }
    [Parameter] public int Quantity { get; set; } = 1;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<(int ProductId, int Quantity)> OnQuantityChanged { get; set; }
    [Parameter] public EventCallback<int> OnRemove { get; set; }

    private async Task HandleQuantityChanged(int newQuantity)
    {
        Quantity = newQuantity;
        await OnQuantityChanged.InvokeAsync((ProductId, newQuantity));
    }
}
