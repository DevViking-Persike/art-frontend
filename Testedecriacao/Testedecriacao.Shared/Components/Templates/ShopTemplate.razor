@namespace Testedecriacao.Shared.Components.Templates
@using Testedecriacao.Shared.Components.Organisms
@using Testedecriacao.Shared.Models

<div class="shop-template @CssClass">
    <StoreHeader StoreName="@StoreName"
                 CartCount="@CartItemCount"
                 OnSearch="OnSearch"
                 OnCartClick="OnCartToggle"
                 OnAccountClick="OnAccountClick" />

    <CategoryNav Categories="@Categories"
                 SelectedCategory="@SelectedCategory"
                 OnCategorySelected="OnCategorySelected" />

    <main class="shop-template-content d-flex">
        <section class="shop-template-products flex-grow-1 p-3">
            @ChildContent
        </section>

        @if (ShowCart)
        {
            <aside class="shop-template-sidebar p-3 border-start" style="min-width: 350px;">
                @CartContent
            </aside>
        }
    </main>
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public RenderFragment? CartContent { get; set; }
    [Parameter] public string StoreName { get; set; } = "Loja";
    [Parameter] public int CartItemCount { get; set; }
    [Parameter] public bool ShowCart { get; set; }
    [Parameter] public IEnumerable<Category> Categories { get; set; } = [];
    [Parameter] public string? SelectedCategory { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<string> OnSearch { get; set; }
    [Parameter] public EventCallback OnCartToggle { get; set; }
    [Parameter] public EventCallback OnAccountClick { get; set; }
    [Parameter] public EventCallback<string?> OnCategorySelected { get; set; }
}
