@namespace Testedecriacao.Shared.Components.Organisms
@using Testedecriacao.Shared.Components.Molecules
@using Testedecriacao.Shared.Models

<div class="product-grid @CssClass">
    @if (Title is not null)
    {
        <h4 class="product-grid-title mb-3">@Title</h4>
    }

    @if (!Products.Any())
    {
        <div class="text-center text-muted py-5">
            <p>Nenhum produto encontrado.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-@Columns g-3">
            @foreach (var product in Products)
            {
                <div class="col">
                    <ProductCard ProductId="@product.Id"
                                 Name="@product.Name"
                                 ImageUrl="@product.ImageUrl"
                                 Price="@product.Price"
                                 OriginalPrice="@product.OriginalPrice"
                                 Category="@product.Category"
                                 RatingValue="@product.Rating"
                                 RatingCount="@product.RatingCount"
                                 BadgeText="@product.BadgeText"
                                 OnSelect="OnProductSelect"
                                 OnAddToCart="OnAddToCart" />
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IEnumerable<Product> Products { get; set; } = [];
    [Parameter] public string? Title { get; set; }
    [Parameter] public int Columns { get; set; } = 4;
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<int> OnProductSelect { get; set; }
    [Parameter] public EventCallback<int> OnAddToCart { get; set; }
}
