@namespace Testedecriacao.Shared.Components.Organisms
@using Testedecriacao.Shared.Components.Atoms
@using Testedecriacao.Shared.Components.Molecules
@using Testedecriacao.Shared.Models

<div class="shopping-cart @CssClass">
    <div class="shopping-cart-header d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Carrinho <Badge Variant="secondary">@Items.Count()</Badge></h5>
    </div>

    @if (!Items.Any())
    {
        <div class="text-center text-muted py-4">
            <p class="mb-0">Seu carrinho está vazio</p>
        </div>
    }
    else
    {
        <div class="shopping-cart-items">
            @foreach (var item in Items)
            {
                <CartItem ProductId="@item.ProductId"
                          Name="@item.Name"
                          ImageUrl="@item.ImageUrl"
                          Price="@item.Price"
                          Quantity="@item.Quantity"
                          OnQuantityChanged="OnQuantityChanged"
                          OnRemove="OnRemoveItem" />
            }
        </div>

        <div class="shopping-cart-footer border-top pt-3 mt-3">
            <div class="d-flex justify-content-between mb-2">
                <span>Subtotal</span>
                <strong>@Subtotal.ToString("C")</strong>
            </div>
            @if (Discount > 0)
            {
                <div class="d-flex justify-content-between mb-2 text-success">
                    <span>Desconto</span>
                    <span>-@Discount.ToString("C")</span>
                </div>
            }
            <div class="d-flex justify-content-between mb-3 fs-5">
                <strong>Total</strong>
                <strong class="text-primary">@Total.ToString("C")</strong>
            </div>
            <Button Variant="success" Size="lg" CssClass="w-100" OnClick="OnCheckout">
                Finalizar Compra
            </Button>
        </div>
    }
</div>

@code {
    [Parameter] public IEnumerable<CartItemModel> Items { get; set; } = [];
    [Parameter] public decimal Discount { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback<(int ProductId, int Quantity)> OnQuantityChanged { get; set; }
    [Parameter] public EventCallback<int> OnRemoveItem { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnCheckout { get; set; }

    private decimal Subtotal => Items.Sum(i => i.Price * i.Quantity);
    private decimal Total => Subtotal - Discount;
}
