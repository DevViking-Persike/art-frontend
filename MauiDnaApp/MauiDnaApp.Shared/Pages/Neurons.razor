@page "/neurons"
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Neural Network Growth</PageTitle>

<div class="neurons-container">
    <canvas id="neuronsCanvas" width="800" height="800"></canvas>
</div>

<style>
    .neurons-container {
        background-color: #050508;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 56px);
        overflow: hidden;
        margin: -1rem;
    }
    canvas {
        max-width: 100%;
        max-height: 100%;
        background: #050508;
    }
</style>

@code {
    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./_content/MauiDnaApp.Shared/neurons.js");
            await module.InvokeVoidAsync("startNeuronsAnimation", "neuronsCanvas");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}
