@page "/networking"
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Constellation Network</PageTitle>

<div class="networking-container">
    <canvas id="networkingCanvas" width="800" height="800"></canvas>
</div>

<style>
    .networking-container {
        background-color: #000814;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 56px);
        overflow: hidden;
        margin: -1rem;
    }
    canvas {
        max-width: 100%;
        max-height: 100%;
        background: #000814;
    }
</style>

@code {
    private IJSObjectReference? module;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./_content/MauiDnaApp.Shared/networking.js");
            await module.InvokeVoidAsync("startNetworkingAnimation", "networkingCanvas");
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}
